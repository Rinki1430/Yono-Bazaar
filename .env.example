# ---------------------------------------------------------------------------
# Premium Telegram Bot — Environment Configuration
# Copy this file to ".env" and fill in your real values.
# ---------------------------------------------------------------------------

# Token from @BotFather
BOT_TOKEN=

# Your numeric Telegram user ID (only this user can access admin features)
ADMIN_ID=

# The channel the bot manages. Use the numeric ID (e.g. -1001234567890)
# or the public @username of the channel.
CHANNEL_ID=

# Default IANA timezone used for scheduling (e.g. Asia/Kolkata, Europe/London, America/New_York)
TIMEZONE=Asia/Kolkata

# Optional: custom path for the SQLite database file
DB_PATH=bot_database.db
