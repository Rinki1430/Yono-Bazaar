# ---------------------------------------------------------------------------
# Premium Telegram Bot — Environment Configuration
# Copy this file to ".env" and fill in your real values.
# ---------------------------------------------------------------------------

# Token from @BotFather
BOT_TOKEN=

# Your numeric Telegram user ID (only this user can access admin features)
ADMIN_ID=

# The channel the bot manages. Use the numeric ID (e.g. -1001234567890)
# or the public @username of the channel.
CHANNEL_ID=

# Default IANA timezone used for scheduling (e.g. Asia/Kolkata, Europe/London, America/New_York)
TIMEZONE=Asia/Kolkata

# Optional: custom path for the SQLite database file
DB_PATH=bot_database.db

# ---------------------------------------------------------------------------
# Automatic Channel Boost Reminder (posts twice a week automatically)
# ---------------------------------------------------------------------------

# The boost link users tap to boost the channel
BOOST_URL=https://t.me/boost/yonobazaars

# Days of week the reminder is sent (comma-separated, 3-letter codes)
# Options: mon,tue,wed,thu,fri,sat,sun  |  Default = mon,thu (2x per week)
BOOST_DAYS=mon,thu

# Time of day the reminder is sent (24h format, in BOOST_TIMEZONE)
BOOST_HOUR=7
BOOST_MINUTE=0

# Timezone for the boost schedule
BOOST_TIMEZONE=Asia/Kolkata
